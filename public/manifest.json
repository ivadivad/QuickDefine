{
  "manifest_version": 3,
  "name": "QuickDefine",
  "version": "2.0",
  "description": "Defina palavras rapidamente com um clique direito",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}